                                     "\n",
                                     "def minmax_norm(series):\n",
                                     "    s_min = series.min(skipna=True)\n",
                                     "    s_max = series.max(skipna=True)\n",
                                     "    if pd.isna(s_min) or pd.isna(s_max) or s_max == s_min:\n",
